{
  "name": "f261agent",
  "version": "1.0.0",
  "description": "OneBot v11 AI assistant framework",
  "license": "GPL-3.0",
  "author": "PhantomDaze",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run typecheck",
    "test:ws": "tsx test/onebot-ws.test.ts",
    "test:kb": "tsx test/knowledge.test.ts",
    "test:all": "npm run typecheck && npm run test:ws && npm run test:kb"
  },
  "dependencies": {
    "@hapi/hapi": "^21.4.9",
    "sql.js": "^1.14.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
